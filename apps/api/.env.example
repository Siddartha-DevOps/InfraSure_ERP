# Copy to .env and adjust as needed.
DATABASE_URL="postgresql://infrasure:infrasure@localhost:5432/infrasure_erp?schema=public"
MONGO_URL="mongodb://localhost:27017"
MONGO_DB="infrasure_audit"
JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="8h"
PORT=4000

# File storage (Phase 1: local disk; S3-ready adapter for later).
STORAGE_DRIVER="local"
UPLOAD_DIR="uploads"

# Billing (Phase 3). Default is a stub driver (no Stripe account needed).
# Set BILLING_DRIVER=stripe and STRIPE_SECRET_KEY to use real Stripe Checkout.
BILLING_DRIVER="stub"
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PRICE_PRO="price_..."
# STRIPE_PRICE_ENTERPRISE="price_..."
# BILLING_SUCCESS_URL="https://app.example.test/billing?status=success"
# BILLING_CANCEL_URL="https://app.example.test/billing?status=cancel"

# AI engine (Phase 4). Python FastAPI service; API degrades gracefully if it's down.
AI_ENGINE_URL="http://localhost:8000"
AI_TIMEOUT_MS=4000

# External integrations. Each is a stub until its credential (configEnv) is set,
# then becomes a real HTTP call. Provide the matching *_API_URL base for the
# key-authenticated portals (GST/EPFO/RERA/Aadhaar); TALLY/BIM use their URL directly.
# TALLY_API_URL="https://tally.example/api"
# GST_PORTAL_API_KEY="..."
# GST_PORTAL_API_URL="https://gstn.example/api"
# EPFO_API_KEY="..."
# EPFO_API_URL="https://epfo.example/api"
# RERA_API_KEY="..."
# RERA_API_URL="https://rera.example/api"
# AADHAAR_ESIGN_API_KEY="..."
# AADHAAR_ESIGN_API_URL="https://esign.example/api"
# BIM_API_URL="https://bim.example/api"
