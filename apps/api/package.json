{
  "name": "@infrasure/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "scheduler": "node src/runScheduler.js",
    "db:generate": "prisma generate --schema ../../packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ../../packages/db/prisma/schema.prisma --name init",
    "db:seed": "node prisma/seed.js",
    "db:setup": "npm run db:generate && npm run db:migrate && npm run db:seed",
    "test": "node --test test/authorize.test.js test/audit.test.js test/auth.test.js test/rbac-coverage.test.js test/geo.test.js test/scheduler.test.js",
    "test:integration": "node --test test/resolvers.integration.test.js"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express4": "^1.1.2",
    "@infrasure/db": "*",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "graphql": "^16.9.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.9.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "prisma": "^5.20.0"
  },
  "optionalDependencies": {
    "stripe": "^16.2.0"
  }
}
