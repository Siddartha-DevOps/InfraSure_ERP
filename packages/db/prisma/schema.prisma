// InfraSure ERP — PostgreSQL schema (shared-schema multi-tenancy).
// Every business table carries tenant_id for strict tenant isolation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ENGINEER
  ACCOUNTANT
  COMPLIANCE_OFFICER
  PROJECT_MANAGER
  ADMIN
  // Platform/company/external roles (dashboard role architecture).
  SUPER_ADMIN
  COMPANY_ADMIN
  CONTRACTOR
  VENDOR
}

model Tenant {
  tenant_id         String   @id @default(uuid())
  company_name      String
  gst_number        String?
  rera_id           String?
  subscription_plan String   @default("BASIC")
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  users         User[]
  subscriptions Subscription[]
  contracts     Contract[]
  finances      Finance[]
  safetyAudits  Safety[]
  dprs          Dpr[]
  envReports    EnvironmentalReport[]
  envLogs       EnvironmentalLog[]
  labourFilings LabourFiling[]
  reraFilings   ReraFiling[]
  vendors       Vendor[]
  disputes      Dispute[]
  sites         Site[]
  projects      Project[]
  contractors   Contractor[]
  workflowSteps WorkflowStep[]
  incidents     Incident[]
  clearances    Clearance[]
  readinessSnapshots ReadinessSnapshot[]
  retrievalEvents    RetrievalEvent[]
  reminders          Reminder[]
}

model User {
  user_id       String    @id @default(uuid())
  tenant_id     String
  email         String    @unique
  password_hash String
  role          Role
  status        String    @default("ACTIVE")
  // Links an external user (CONTRACTOR/VENDOR) to their Contractor/Vendor record.
  linked_id     String?
  created_at    DateTime  @default(now())
  last_login    DateTime?

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

model Subscription {
  subscription_id        String    @id @default(uuid())
  tenant_id              String
  plan_type              String    @default("BASIC") // BASIC | PRO | ENTERPRISE
  billing_cycle          String    @default("MONTHLY")
  stripe_customer_id     String?
  stripe_subscription_id String?
  current_period_end     DateTime?
  status                 String    @default("ACTIVE")
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

// Vendor / subcontractor registry with certification-expiry tracking.
model Vendor {
  vendor_id            String    @id @default(uuid())
  tenant_id            String
  name                 String
  gst_number           String?
  certification_name   String?
  certification_expiry DateTime?
  status               String    @default("ACTIVE") // ACTIVE | SUSPENDED
  created_at           DateTime  @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

// Risk / dispute register with escalation workflow.
model Dispute {
  dispute_id       String    @id @default(uuid())
  tenant_id        String
  title            String
  dispute_type     String    @default("CONTRACT") // CONTRACT | PAYMENT | SAFETY | OTHER
  counterparty     String?
  amount           Float     @default(0)
  status           String    @default("OPEN") // OPEN | IN_ARBITRATION | ESCALATED | RESOLVED
  escalation_level Int       @default(0)
  opened_at        DateTime  @default(now())
  resolved_at      DateTime?

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

model Contract {
  contract_id   String   @id @default(uuid())
  tenant_id     String
  project_id    String?
  title         String
  contract_type String   @default("AGREEMENT") // AGREEMENT | WORK_ORDER | INSURANCE | OTHER
  expiry_date   DateTime
  status        String   @default("DRAFT")
  document_url  String?
  version       Int      @default(1)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  project Project? @relation(fields: [project_id], references: [project_id], onDelete: SetNull)

  @@index([tenant_id])
}

model Finance {
  finance_id        String    @id @default(uuid())
  tenant_id         String
  invoice_number    String?
  filing_period     String? // e.g. "2026-Q1" or "2026-05"
  gst_filing_status String    @default("PENDING") // PENDING | FILED
  tds_status        String    @default("PENDING") // PENDING | FILED
  ra_bill_status    String    @default("PENDING") // PENDING | APPROVED
  amount            Float     @default(0)
  due_date          DateTime
  paid_date         DateTime? // null = unpaid; drives payment-aging KPI
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

model Safety {
  safety_id           String   @id @default(uuid())
  tenant_id           String
  site_name           String?
  audit_date          DateTime @default(now())
  checklist_status    String   @default("PENDING") // PENDING | COMPLETED | FAILED
  ppe_compliance      Int      @default(0) // PPE checklist compliance %
  incident_report_url String?
  created_at          DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

// Environmental clearances / statutory consents with renewal tracking.
// renewal health (VALID/EXPIRING/EXPIRED) is derived from expiry_date.
model Clearance {
  clearance_id   String    @id @default(uuid())
  tenant_id      String
  project_id     String?
  clearance_type String    @default("OTHER") // CONSENT_TO_OPERATE | CONSENT_TO_ESTABLISH | FOREST | CRZ | ENVIRONMENTAL_CLEARANCE | OTHER
  authority      String? // issuing body, e.g. SPCB / MoEFCC
  reference_no   String?
  issue_date     DateTime?
  expiry_date    DateTime
  status         String    @default("ACTIVE") // ACTIVE | RENEWED | EXPIRED
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  tenant  Tenant   @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  project Project? @relation(fields: [project_id], references: [project_id], onDelete: SetNull)

  @@index([tenant_id])
}

// Periodic point-in-time snapshot of the audit-readiness score for trend
// charting. A daily scheduler (or manual capture) appends one per tenant per day.
model ReadinessSnapshot {
  snapshot_id            String   @id @default(uuid())
  tenant_id              String
  score                  Float    @default(0)
  documents_verified     Int      @default(0)
  documents_total        Int      @default(0)
  pending_approvals      Int      @default(0)
  open_disputes          Int      @default(0)
  vendor_compliance_rate Float    @default(0)
  captured_at            DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

// System-generated compliance reminders (created by the daily scheduler).
// e.g. "GST filing due tomorrow" — proactive, before the deadline lapses.
model Reminder {
  reminder_id String    @id @default(uuid())
  tenant_id   String
  kind        String    @default("GST_DUE") // GST_DUE | CLEARANCE_EXPIRY | CONTRACT_EXPIRY
  message     String
  due_date    DateTime?
  ref_id      String? // source record id (finance_id / clearance_id …)
  status      String    @default("PENDING") // PENDING | DISMISSED
  created_at  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

// Audit document-retrieval timing: how fast an evidence pack / document / export
// is produced. Powers the "avg document retrieval" KPI in the Reports module.
model RetrievalEvent {
  retrieval_id String   @id @default(uuid())
  tenant_id    String
  user_id      String?
  kind         String   @default("PACK") // PACK | EXPORT | DOCUMENT
  label        String?
  duration_ms  Int      @default(0)
  retrieved_at DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

// Pollution / waste readings for environmental compliance.
model EnvironmentalLog {
  env_log_id  String   @id @default(uuid())
  tenant_id   String
  log_type    String // POLLUTION | WASTE
  reading     Float    @default(0)
  unit        String   @default("")
  notes       String?
  recorded_at DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

// Labour-law filings: PF / ESI / wage registers.
model LabourFiling {
  labour_id    String    @id @default(uuid())
  tenant_id    String
  filing_type  String // PF | ESI | WAGE_REGISTER
  period       String // e.g. "2026-05"
  worker_count Int       @default(0)
  amount       Float     @default(0)
  status       String    @default("PENDING") // PENDING | FILED
  filed_date   DateTime?
  created_at   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

// RERA project filings & updates.
model ReraFiling {
  filing_id    String    @id @default(uuid())
  tenant_id    String
  project_name String
  filing_type  String    @default("QUARTERLY_UPDATE")
  status       String    @default("PENDING") // PENDING | FILED | APPROVED
  due_date     DateTime
  filed_date   DateTime?
  created_at   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

model Dpr {
  dpr_id      String   @id @default(uuid())
  tenant_id   String
  report_data String
  created_at  DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

model EnvironmentalReport {
  report_id   String   @id @default(uuid())
  tenant_id   String
  report_data String
  created_at  DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

// Subcontractor registry (distinct from material Vendors) for the Contractor role.
model Contractor {
  contractor_id    String   @id @default(uuid())
  tenant_id        String
  name             String
  trade            String? // e.g. "Civil", "Electrical", "Scaffolding"
  contact_email    String?
  active_projects  Int      @default(0)
  compliance_score Int      @default(100) // 0-100
  status           String   @default("ACTIVE") // ACTIVE | SUSPENDED
  created_at       DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}

// A construction project — groups contracts and sites for a compliance roll-up.
model Project {
  project_id String   @id @default(uuid())
  tenant_id  String
  code       String // e.g. "PRJ-001"
  name       String
  location   String?
  created_at DateTime @default(now())

  tenant    Tenant     @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  contracts  Contract[]
  sites      Site[]
  incidents  Incident[]
  clearances Clearance[]

  @@index([tenant_id])
}

// Safety incident log: injuries, near-misses, property/environmental events.
// A first-class, queryable entity (distinct from the periodic Safety audit).
model Incident {
  incident_id String    @id @default(uuid())
  tenant_id   String
  project_id  String?
  title       String
  site_name   String?
  category    String    @default("OTHER") // INJURY | NEAR_MISS | PROPERTY_DAMAGE | ENVIRONMENTAL | OTHER
  severity    String    @default("LOW") // LOW | MEDIUM | HIGH | CRITICAL
  status      String    @default("OPEN") // OPEN | INVESTIGATING | RESOLVED | CLOSED
  description String?
  reported_by String?
  occurred_at DateTime  @default(now())
  resolved_at DateTime?
  created_at  DateTime  @default(now())

  tenant  Tenant   @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  project Project? @relation(fields: [project_id], references: [project_id], onDelete: SetNull)

  @@index([tenant_id])
}

// Geo-tagged project sites for the compliance map.
model Site {
  site_id    String   @id @default(uuid())
  tenant_id  String
  project_id String?
  name       String
  latitude   Float
  longitude  Float
  status     String   @default("PENDING") // COMPLIANT | PENDING | NON_COMPLIANT
  created_at DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  project Project? @relation(fields: [project_id], references: [project_id], onDelete: SetNull)

  @@index([tenant_id])
}

model WorkflowStep {
  step_id    String   @id @default(uuid())
  tenant_id  String
  name       String   @default("Compliance step")
  status     String   @default("PENDING")
  created_at DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id])
}
